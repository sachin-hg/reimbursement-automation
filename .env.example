# ── Gmail account to open in the browser ──────────────────────────────────────
# The script opens mail.google.com and checks you're on this account.
GMAIL_ADDRESS=a.sachin533@gmail.com

# ── Email filters ──────────────────────────────────────────────────────────────
# Who sends the petrol bills
SENDER_EMAIL=monika.aggarwal1992@gmail.com
# Gmail label name (spaces OK — the script converts them to hyphens for search)
GMAIL_LABEL=Petrol Bill
# How many days back to look for emails (default: 2)
LOOKBACK_DAYS=2

# ── Anthropic / Claude ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Payroll Portal ─────────────────────────────────────────────────────────────
# If set, credentials are filled automatically. If left blank, fill them
# manually in the browser window when it opens.
PORTAL_USERNAME=your_portal_username
PORTAL_PASSWORD=your_portal_password

# ── Portal browser ─────────────────────────────────────────────────────────────
# true = headless (faster, no window); false = show browser window for debugging
HEADLESS=false

# ── Cross-origin deployment (Vercel frontend + external backend) ───────────────
# Comma-separated list of frontend origins allowed to call this server.
# Leave blank for same-origin / local dev.
# Example: CORS_ORIGINS=https://myapp.vercel.app
CORS_ORIGINS=

# Backend port (default: 3333)
PORT=3333
